<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml" 
            fx:controller="com.hiddeninpixel.ui.controllers.MainController"
            prefWidth="1200" prefHeight="800">
    
    <top>
        <HBox alignment="CENTER" spacing="20" styleClass="header">
            <padding><Insets top="15" bottom="15"/></padding>
            <Label text="Hidden-In-Pixel" style="-fx-font-size: 24px; -fx-text-fill: #f8fafc; -fx-font-weight: bold;"/>
            <Label text="Steganography Suite" style="-fx-font-size: 16px; -fx-text-fill: #3b82f6;"/>
        </HBox>
    </top>
    
    <center>
        <TabPane fx:id="mainTabPane">
            <tabs>
                <!-- ENCODE TAB -->
                <Tab text="Encode (Hide)" closable="false">
                    <VBox spacing="20" alignment="TOP_CENTER">
                        <padding><Insets top="30" left="60" right="60" bottom="20"/></padding>
                        
                        <HBox spacing="30" alignment="TOP_CENTER" VBox.vgrow="ALWAYS">
                            <!-- Left Column: Image Drop Zone -->
                            <VBox spacing="10" alignment="CENTER" HBox.hgrow="ALWAYS">
                                <Label text="Cover Image"/>
                                <StackPane fx:id="encodeDropZone" styleClass="drop-zone" prefWidth="450" prefHeight="350">
                                    <VBox alignment="CENTER" spacing="10">
                                        <Label text="Drag &amp; Drop Image Here" style="-fx-text-fill: #94a3b8; -fx-font-size: 16px;"/>
                                        <Label text="or click to browse" style="-fx-text-fill: #64748b;"/>
                                        <Button text="Browse File" onAction="#handleLoadEncodeImage"/>
                                    </VBox>
                                    <ImageView fx:id="encodeImageView" fitWidth="430" fitHeight="330" preserveRatio="true" visible="false"/>
                                </StackPane>
                                <Button text="Clear" onAction="#handleClearEncodeImage" visible="false" fx:id="clearEncodeBtn"/>
                            </VBox>
                            
                            <!-- Right Column: Settings & Input -->
                            <VBox spacing="20" HBox.hgrow="SOMETIMES" prefWidth="400">
                                <VBox spacing="5">
                                    <Label text="Algorithm:"/>
                                    <ComboBox fx:id="encodeAlgorithmCombo" maxWidth="Infinity"/>
                                </VBox>
                                
                                <VBox spacing="5">
                                    <Label text="Password / Key:"/>
                                    <PasswordField fx:id="encodePasswordField" promptText="Optional for Sequential"/>
                                </VBox>
                                
                                <VBox spacing="5" VBox.vgrow="ALWAYS">
                                    <Label text="Secret Message:"/>
                                    <TextArea fx:id="encodeMessageArea" promptText="Enter the text to hide within the image..." wrapText="true" VBox.vgrow="ALWAYS"/>
                                </VBox>
                                
                                <Button text="Hide Message &amp; Save" onAction="#handleEncode" maxWidth="Infinity" style="-fx-padding: 15px; -fx-font-size: 16px;"/>
                            </VBox>
                        </HBox>
                        
                        <!-- Status Bar -->
                        <HBox alignment="CENTER_LEFT" spacing="20">
                            <ProgressBar fx:id="encodeProgressBar" prefWidth="300" progress="0.0"/>
                            <Label fx:id="encodeStatusLabel" styleClass="status-label" text="Ready to Encode"/>
                        </HBox>
                    </VBox>
                </Tab>
                
                <!-- DECODE TAB -->
                <Tab text="Decode (Extract)" closable="false">
                    <VBox spacing="20" alignment="TOP_CENTER">
                        <padding><Insets top="30" left="60" right="60" bottom="20"/></padding>
                        
                        <HBox spacing="30" alignment="TOP_CENTER" VBox.vgrow="ALWAYS">
                            <!-- Left Column: Image Drop Zone -->
                            <VBox spacing="10" alignment="CENTER" HBox.hgrow="ALWAYS">
                                <Label text="Stego Image (Contains secret)"/>
                                <StackPane fx:id="decodeDropZone" styleClass="drop-zone" prefWidth="450" prefHeight="350">
                                    <VBox alignment="CENTER" spacing="10">
                                        <Label text="Drag &amp; Drop Stego Image Here" style="-fx-text-fill: #94a3b8; -fx-font-size: 16px;"/>
                                        <Button text="Browse File" onAction="#handleLoadDecodeImage"/>
                                    </VBox>
                                    <ImageView fx:id="decodeImageView" fitWidth="430" fitHeight="330" preserveRatio="true" visible="false"/>
                                </StackPane>
                                <Button text="Clear" onAction="#handleClearDecodeImage" visible="false" fx:id="clearDecodeBtn"/>
                            </VBox>
                            
                            <!-- Right Column: Settings & Output -->
                            <VBox spacing="20" HBox.hgrow="SOMETIMES" prefWidth="400">
                                <VBox spacing="5">
                                    <Label text="Algorithm used:"/>
                                    <ComboBox fx:id="decodeAlgorithmCombo" maxWidth="Infinity"/>
                                </VBox>
                                
                                <VBox spacing="5">
                                    <Label text="Password / Key:"/>
                                    <PasswordField fx:id="decodePasswordField" promptText="Must exactly match the key used to hide"/>
                                </VBox>
                                
                                <Button text="Extract Message" onAction="#handleDecode" maxWidth="Infinity" style="-fx-padding: 15px; -fx-font-size: 16px;"/>
                                
                                <VBox spacing="5" VBox.vgrow="ALWAYS">
                                    <Label text="Extracted Secret Message:"/>
                                    <TextArea fx:id="decodeMessageArea" editable="false" promptText="Message will appear here after extraction..." wrapText="true" VBox.vgrow="ALWAYS"/>
                                </VBox>
                            </VBox>
                        </HBox>
                        
                        <!-- Status Bar -->
                        <HBox alignment="CENTER_LEFT" spacing="20">
                            <ProgressBar fx:id="decodeProgressBar" prefWidth="300" progress="0.0"/>
                            <Label fx:id="decodeStatusLabel" styleClass="status-label" text="Ready to Decode"/>
                        </HBox>
                    </VBox>
                </Tab>
                
                <!-- ANALYTICS TAB -->
                <Tab text="Analytics &amp; Forensics" closable="false">
                    <fx:include source="analytics.fxml"/>
                </Tab>
            </tabs>
        </TabPane>
    </center>
    
</BorderPane>
